@using Microsoft.Extensions.Options

@inject IOptions<FgrOptions> Options

@if (Options.Value.AreDiagnosticsEnabled)
{
    <CascadingValue
        Name="popover-id"
        Value="@PopoverId"
        IsFixed="true">
        <CascadingValue Value="@Diagnostics()">
            @Options.Value.DiagnosticsPopoverContent
            <div class="@Class"></div>
        </CascadingValue>
    </CascadingValue>
}

@code {

    private string Class => "fgr-diagnostics-anchor" + Options.Value.DiagnosticsAnchorAdditionalClass?.Trim();

    [Parameter]
    public string PopoverId { get; set; } = $"fgr-diagnostics-{Guid.NewGuid()}";

    [Parameter]
    [EditorRequired]
    public Func<FgrDiagnostics> Diagnostics { get; set; }

}