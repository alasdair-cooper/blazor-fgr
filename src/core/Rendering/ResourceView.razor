@using BlazorFgr.Core.Primitives.Resource

@typeparam TResult

@switch (Value)
{
    case ResourceValue<TResult>.Loading:
        @Loading
        break;
    case ResourceValue<TResult>.Errored(var ex):
        @Errored?.Invoke(ex)
        break;
    case ResourceValue<TResult>.Loaded(var val):
        @Loaded?.Invoke(val)
        break;
}

@code {

    [Parameter]
    [EditorRequired]
    public ResourceValue<TResult> Value { get; set; }

    [Parameter]
    public RenderFragment? Loading { get; set; }

    [Parameter]
    public RenderFragment<Exception>? Errored { get; set; }

    [Parameter]
    public RenderFragment<TResult>? Loaded { get => field ?? ChildContent; set; }

    [Parameter]
    public RenderFragment<TResult>? ChildContent { get; set; }

}