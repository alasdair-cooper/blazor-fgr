@using BlazorFgr.Core.Primitives.Dispatcher

@switch (Value)
{
    case DispatcherValue.Running:
        @Running
        break;
    case DispatcherValue.Errored(var ex):
        @Errored?.Invoke(ex)
        break;
    case DispatcherValue.Sleeping:
        @Sleeping
        break;
}

@code {

    [Parameter]
    [EditorRequired]
    public DispatcherValue Value { get; set; }

    [Parameter]
    public RenderFragment? Running { get; set; }

    [Parameter]
    public RenderFragment<Exception>? Errored { get; set; }

    [Parameter]
    public RenderFragment? Sleeping { get; set; }

}