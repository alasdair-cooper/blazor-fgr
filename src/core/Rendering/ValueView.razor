@using BlazorFgr.Core.Primitives

@typeparam T where T : IEquatable<T>

<FgrView Value="Value">
    @ChildContent?.Invoke(context)
</FgrView>

@code {

    [Parameter]
    [EditorRequired]
    public IGettable<T> Value { get; set; }

    [Parameter]
    public RenderFragment<T>? ChildContent { get; set; }

}